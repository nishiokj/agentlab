{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/trial_state_v1.json",
  "title": "Trial State v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trial_id", "status", "updated_at"],
  "properties": {
    "schema_version": { "const": "trial_state_v1" },
    "trial_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "pause_label": { "type": ["string", "null"] },
    "checkpoint_selected": { "type": ["string", "null"] },
    "exit_reason": { "type": ["string", "null"] },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
