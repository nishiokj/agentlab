{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/control_plane_v1.json",
  "title": "Control Plane v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "seq", "action", "requested_at", "requested_by"],
  "properties": {
    "schema_version": { "const": "control_plane_v1" },
    "seq": { "type": "integer", "minimum": 0 },
    "action": { "type": "string", "minLength": 1 },
    "label": { "type": ["string", "null"] },
    "requested_at": { "type": "string", "minLength": 1 },
    "requested_by": { "type": "string", "minLength": 1 }
  }
}
