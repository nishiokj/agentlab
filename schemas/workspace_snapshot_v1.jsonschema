{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/workspace_snapshot_v1.json",
  "title": "Workspace Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "captured_at", "file_count", "total_bytes", "files"],
  "properties": {
    "schema_version": { "const": "workspace_snapshot_v1" },
    "captured_at": { "type": "string", "minLength": 1 },
    "file_count": { "type": "integer", "minimum": 0 },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "digest", "size_bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
