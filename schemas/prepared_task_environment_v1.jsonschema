{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/prepared_task_environment_v1.json",
  "title": "Prepared Task Environment v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "declaration",
    "declaration_digest",
    "run_id",
    "trial_id",
    "variant_id",
    "task_id",
    "task_index",
    "repl_idx",
    "task_image",
    "workspace_root",
    "aux_mounts",
    "contract_files",
    "runtime_env"
  ],
  "properties": {
    "schema_version": { "const": "prepared_task_environment_v1" },
    "declaration": {
      "type": "object",
      "additionalProperties": true
    },
    "declaration_digest": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "trial_id": { "type": "string", "minLength": 1 },
    "variant_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "task_index": { "type": "integer", "minimum": 0 },
    "repl_idx": { "type": "integer", "minimum": 0 },
    "task_image": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "aux_mounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["host_path", "mount_path"],
        "properties": {
          "host_path": { "type": "string", "minLength": 1 },
          "mount_path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "contract_files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trial_input", "task", "bindings", "dependencies", "policy", "result", "trajectory"],
      "properties": {
        "trial_input": { "type": "string", "minLength": 1 },
        "task": { "type": "string", "minLength": 1 },
        "bindings": { "type": "string", "minLength": 1 },
        "dependencies": { "type": "string", "minLength": 1 },
        "policy": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "minLength": 1 },
        "trajectory": { "type": "string", "minLength": 1 }
      }
    },
    "runtime_env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
