{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/sealed_package_checksums_v2.json",
  "title": "Sealed Package Checksums v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "files"],
  "properties": {
    "schema_version": { "const": "sealed_package_checksums_v2" },
    "files": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
    }
  }
}
