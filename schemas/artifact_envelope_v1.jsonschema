{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/artifact_envelope_v1.json",
  "title": "Artifact Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "artifact"],
  "properties": {
    "schema_version": { "const": "artifact_envelope_v1" },
    "artifact_type": {
      "type": "string",
      "enum": [
        "patch_submission",
        "text_response",
        "structured_json",
        "file_ref"
      ]
    },
    "artifact": {
      "description": "Artifact payload. Shape depends on artifact_type."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
