{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lab.local/schemas/run_manifest_v1.json",
  "title": "Run Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "workload_type",
    "baseline_id",
    "variant_ids"
  ],
  "properties": {
    "schema_version": { "const": "run_manifest_v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "workload_type": { "type": "string", "minLength": 1 },
    "baseline_id": { "type": "string", "minLength": 1 },
    "variant_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
